{
  "name": "enhancer-for-gemini",
  "displayName": "Enhancer for Gemini",
  "version": "1.2",
  "description": "Supercharge your Google Gemini experience with a prompt library, favorite responses, and quick notes.",
  "author": "Yağız Berke Güvenç",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv3",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "i18next": "^26.0.8",
    "plasmo": "^0.90.5",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^17.0.6"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/chrome": "0.1.40",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  },
  "manifest": {
    "name": "__MSG_extensionName__",
    "description": "__MSG_extensionDescription__",
    "default_locale": "en",
    "host_permissions": [
      "https://gemini.google.com/*"
    ],
    "permissions": [
      "storage"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "enhancer-for-gemini@berkeguvenc.com",
        "strict_min_version": "140.0",
        "data_collection_permissions": {
          "required": [
            "none"
          ]
        }
      }
    }
  }
}